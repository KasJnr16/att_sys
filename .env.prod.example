ENVIRONMENT=production
PROJECT_NAME=University Attendance System
SECRET_KEY=replace-with-a-long-random-secret-key-at-least-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=11520
ALGORITHM=HS256

# Use your Neon direct connection string.
SQLALCHEMY_DATABASE_URI=postgresql://user:password@host/neondb?sslmode=require&channel_binding=require

BACKEND_PORT=8000
FRONTEND_PORT=3000

RP_ID=your-frontend-domain.vercel.app
RP_NAME=University Attendance System
ORIGIN=https://your-frontend-domain.vercel.app
BACKEND_CORS_ORIGINS=https://your-frontend-domain.vercel.app

NEXT_PUBLIC_API_URL=https://your-backend-domain.onrender.com/api/v1
